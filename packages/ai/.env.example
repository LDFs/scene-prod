# Qwen / DashScope 配置示例。复制为 .env 并填入真实值，切勿提交真实 Key。

# 必填：DashScope API Key（控制台获取）
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：OpenAI 兼容接口地址（默认即为下方地址）
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：默认模型（qwen-plus / qwen-max / qwen-turbo 等）
# QWEN_MODEL=qwen-plus

# 可选：采样温度、最大 token、超时（毫秒）
# AI_TEMPERATURE=0.7
# AI_MAX_TOKENS=2048
# AI_TIMEOUT=60000
