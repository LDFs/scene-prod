{
  "name": "@scene-prod/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared types, schema definitions and constants for scene-prod editor / runtime / server",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./schema": "./src/schema.ts",
    "./types": "./src/types/index.ts",
    "./constants": "./src/constants.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"TODO: lint\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "three": "^0.181.2",
    "tsup": "^8.0.0"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./schema": {
        "types": "./dist/schema.d.ts",
        "import": "./dist/schema.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js"
      },
      "./constants": {
        "types": "./dist/constants.d.ts",
        "import": "./dist/constants.js"
      }
    }
  }
}
