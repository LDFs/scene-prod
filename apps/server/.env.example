# ── 本地开发（Node 跑在宿主机，连 compose 暴露出来的端口）──
PORT=3100
MONGODB_URL=mongodb://localhost:27017/scene-prod
REDIS_URL=redis://localhost:6380

# ── 生产（仅供 docker-compose.prod.yml 注入，server 容器内走服务名访问）──
# 把下面的值放进根目录的 .env（不要提交），compose 会读取：
#   MONGO_USER=app
#   MONGO_PASSWORD=<强密码>
#   REDIS_PASSWORD=<强密码>

QWEN_API_KEY=YOUR KEY

# 可选：OpenAI 兼容接口地址（默认即为下方地址）
QWEN_BASE_URL=URL

# 可选：默认模型（qwen-plus / qwen-max / qwen-turbo 等）
QWEN_MODEL=qwen-plus

COS_SECRET_ID=
COS_SECRET_KRY=
