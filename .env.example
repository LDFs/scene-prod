# 生产部署密钥模板。复制为根目录 .env 后填入真实值（.env 已被 gitignore，勿提交）。
# docker compose -f docker-compose.yml -f docker-compose.prod.yml 会自动读取本目录的 .env。

# ── 数据库 / 队列（compose 内部服务名访问，密码务必用强随机值）──
MONGO_USER=app
MONGO_PASSWORD=change_me_strong
REDIS_PASSWORD=change_me_strong

# ── 前端 API 地址：同域 Nginx 反代部署留空即可（走相对路径）──
VITE_API_BASE_URL=

# ── 后端 CORS：同域部署留空；若前端另开域名，填 https://你的前端域名 ──
CORS_ORIGINS=

# ── AI（Qwen / OpenAI 兼容接口）──
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-plus

# ── 腾讯云 COS（如使用对象存储）──
COS_SECRET_ID=
COS_SECRET_KRY=
